# ========== Frontend (Vite) ==========
# Em dev (recomendado): copia as duas linhas abaixo tal como estão.
# — VITE_API_BASE_URL vazio → o browser chama /api/* no Vite (5173) e o Vite faz proxy para a API.
# — VITE_API_PROXY_TARGET deve coincidir com a API (PORT default 3000).
# — No Windows: variáveis VITE_* no Ambiente do utilizador sobrepõem o .env; remove-as em dev se vires HTML em vez de JSON.
# Produção / Vercel: define VITE_API_BASE_URL=https://tua-api.com (sem barra final) e NÃO uses proxy.
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://localhost:3000

# Supabase Auth (browser) — obrigatório para o painel; mesmo projeto que a API
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# ========== API (Node) ==========
# O ficheiro principal é este (.env na RAIZ). O `api/server.ts` carrega-o PRIMEIRO.
# Opcional: também podes ter `api/.env` — só preenche variáveis que ainda não existem.
# Ver docs/DEV-SETUP.md
#
# PORT=3000

# Token da Graph API (Page/System User). Use UM dos nomes:
# META_GRAPH_ACCESS_TOKEN=
# ou legado:
# META_ACCESS_TOKEN=

# ID numérico da conta comercial do Instagram (Instagram Business Account)
# INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Supabase (métricas no painel vêm daqui após sync)
# SUPABASE_URL=
# Preferível service role no backend:
# SUPABASE_SERVICE_ROLE_KEY=
# ou:
# SUPABASE_ANON_KEY=

# OPENAI_API_KEY=
# O resumo executivo do Dashboard só chama OpenAI ao clicar no botão; o texto é lido do Supabase no F5.

# Log de diagnóstico: resposta bruta de /insights de audiência (consola do processo `yarn api`)
# DEBUG_IG_AUDIENCE=true

# Log de diagnóstico: GET /{media-id}/insights (alcance por mídia na rota /api/instagram/media)
# DEBUG_IG_MEDIA_INSIGHTS=1

# ========== Studio NFL (página /studio — `src/studio`) ==========
# Ordem: cada chave `VITE_*_STUDIO` tem prioridade; se vazia, usa `VITE_*` sem sufixo.
#
# VITE_SUPABASE_URL_STUDIO=
# VITE_SUPABASE_ANON_KEY_STUDIO=
# VITE_CLOUDINARY_CLOUD_NAME_STUDIO=
# VITE_CLOUDINARY_UPLOAD_PRESET_STUDIO=
# VITE_REPLICATE_API_TOKEN_STUDIO=
# VITE_OPENAI_API_KEY_STUDIO=
# (O Studio também usa OPENAI_API_KEY da raiz — a mesma da API — injetada no cliente pelo Vite.)
# Opcional: URL do blog/Next para legenda IA (senão = origem do Vite)
# VITE_NFL_BLOG_URL_STUDIO=
#
# Fallback (mesmo .env do InstaPulse, se _STUDIO não preenchido):
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# VITE_CLOUDINARY_CLOUD_NAME=
# VITE_CLOUDINARY_UPLOAD_PRESET=
# VITE_REPLICATE_API_TOKEN=
# VITE_OPENAI_API_KEY=
# VITE_NFL_BLOG_URL=
