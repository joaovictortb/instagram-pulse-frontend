{
  "entities": {
    "AIInsight": {
      "title": "AI Insight",
      "description": "A generated AI insight for a specific metric or content.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the insight."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this insight."
        },
        "type": {
          "type": "string",
          "enum": ["dashboard", "growth", "content"],
          "description": "The category of the insight."
        },
        "content": {
          "type": "string",
          "description": "The markdown content of the AI insight."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the insight was generated."
        }
      },
      "required": ["userId", "type", "content", "createdAt"]
    }
  },
  "firestore": {
    "/insights/{insightId}": {
      "schema": "AIInsight",
      "description": "Collection of AI-generated insights."
    }
  }
}
